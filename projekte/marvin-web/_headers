# Security-Header fuer alle Seiten (Cloudflare Pages liest diese Datei beim Deploy).
# Bewusst ohne CSP: die Seiten haben Inline-JS/CSS, ein strikter CSP wuerde sie brechen.
# HSTS wird ueber das Cloudflare-Dashboard gesetzt, nicht per Header-Datei.
#
# noindex-Historie: Bis 2026-07-21 stand hier X-Robots-Tag: noindex auf /* (Schutz der
# Wegwerf-URL pages.dev vor dem Domain-Launch). Beim Launch vergessen zu entfernen ->
# Live-Domain blieb aus dem Google-Index (PageSpeed-Fund 2026-07-21). NICHT wieder einfuehren;
# pages.dev-Duplikate faengt der canonical auf marvinwebdesign.de ab.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Umzugs-Seite (/umzug): bleibt IMMER noindex, auch nachdem oben die site-weite /*-Zeile
# beim Domain-Launch entfernt wird. Zusaetzlich zur <meta name="robots" noindex> in umzug.html.
/umzug
  X-Robots-Tag: noindex

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
