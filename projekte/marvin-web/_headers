# Security-Header fuer alle Seiten (Cloudflare Pages liest diese Datei beim Deploy).
# Bewusst ohne CSP: die Seiten haben Inline-JS/CSS, ein strikter CSP wuerde sie brechen.
# HSTS wird ueber das Cloudflare-Dashboard gesetzt, nicht per Header-Datei.
#
# noindex: seit dem Domain-Launch (2026-07-19) NICHT mehr site-weit — die 6 Business-Seiten
# sind indexierbar. Seiten, die draussen bleiben (impressum/datenschutz/danke/404/umzug),
# tragen ihr eigenes <meta name="robots" content="noindex"> im HTML; /umzug zusaetzlich der
# X-Robots-Tag-Block weiter unten (Landing Page, bleibt IMMER noindex).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Umzugs-Seite (/umzug): bleibt IMMER noindex, auch nachdem oben die site-weite /*-Zeile
# beim Domain-Launch entfernt wird. Zusaetzlich zur <meta name="robots" noindex> in umzug.html.
/umzug
  X-Robots-Tag: noindex

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
